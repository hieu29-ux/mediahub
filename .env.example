# ── Spotify ──────────────────────────────────────────────────────
# Lấy tại: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_REDIRECT_URI=mediahub://callback/spotify

# ── YouTube ──────────────────────────────────────────────────────
# Lấy tại: https://console.cloud.google.com
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
VITE_YOUTUBE_CLIENT_ID=your_youtube_client_id_here
VITE_YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
VITE_YOUTUBE_REDIRECT_URI=mediahub://callback/youtube
